DATABASE_URL="postgresql://user:password@localhost:5432/financesite"
NEXTAUTH_SECRET="replace-with-a-long-secret"
NEXTAUTH_URL="http://localhost:3000"

# Demo credentials for CredentialsProvider (required for sign-in)
DEMO_LOGIN_EMAIL="demo@example.com"
DEMO_LOGIN_PASSWORD="replace-with-a-strong-password"

# Optional: allow demo auth in production (defaults to false)
ALLOW_DEMO_AUTH="false"

# Required for Brevo newsletter API access
BREVO_API_KEY=""

# Optional: Brevo list to attach subscribers to
BREVO_LIST_ID=""

# Redis caching for AI Money Copilot (Upstash Redis REST API)
# Create a free database at https://upstash.com and copy the REST URL + token.
# When unset the system falls back to an in-memory cache automatically.
REDIS_URL=""
REDIS_TOKEN=""
